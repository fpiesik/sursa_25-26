pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
 pl={x=120,y=104,dy=0,iw=1,wc=0,f=false}
 gravity=0.4
 solid = false
 frames={1,3,5,7}
 camera(8,32)
 e={sp=10,x=10,y=88,speed=1}
 ts_r = 300
 failure=false
 win=false
 sp = 29
 sfx(0)
 steps=0
 lives = 3
 failed=false
 running=1
 r=0
 tf=false
end

function _update()
 if win then r+=1 end
 running+=0.5
 if running >= 4 then running = 1 end
 if steps>=6 and pl.dy==0 then steps=0 sfx(4) end
 if not failure and not win then
  if not failed then ts_r-=0.85 end
  if ts_r<=30 and failure==false and failed==false then camera(200,0) win=true end
 
  if pl.x>=123 then pl.x=123 end
 
  if pl.x<=5 then pl.x=5 end
 
  if pl.y <= 0 then pl.dy=0 end
 
  if (is_solid(pl.x,pl.y,0)==true) then solid=true else solid=false end

  if pl.dy<3 then pl.dy+=gravity end 
 
  if (is_solid(pl.x,pl.y,1)==true) then solid=true end
 
  if solid then pl.dy=0 end
  
  if btn(➡️) or btn(⬅️) then steps+=1 else steps=0 end
  
  if btn(➡️) then pl.wc=0 pl.f=false pl.iw+=0.3 pl.x+=1 else pl.wc+=1 end
 
  if btn(⬅️) then pl.wc=0 pl.f=true pl.iw+=0.3 pl.x-=1.1 else pl.wc+=1 end
 
  if btn(⬆️) and pl.dy==0 then pl.dy=-5 sfx(2) end
 
  if pl.iw>=5 then pl.iw = 1 end
  if pl.wc>=7 then pl.wc=0 pl.iw=1 end
  pl.y+=pl.dy 
  if e.x < pl.x then tf=false e.x+=e.speed end
  if e.y < pl.y then e.y+=e.speed end
  if e.x > pl.x then tf=true e.x-=e.speed end
  if e.y > pl.y then e.y-=e.speed end
 
  if flr(e.x) == flr(pl.x) and flr(e.y) == flr(pl.y) and win==false then failure=true end
  sp+=0.25
  if sp>32 then sp=29 end
 end
 if failure then
  camera(8,256)
  sfx(3)
  lives-=1
  failure=false
  e.y=10000
  failed=true 
 end
 if failed and lives>0 then
  if btn(❎) then
   pl.x = 120
   pl.y = 104
   e.y = 88
   e.x = 10
   ts_r = 300
   failure=false
   win=false
   failed=false
   camera(8,32)
  end
 end
end

function is_solid(x,y,t)
 if t==0 and (fget(mget(flr(x/8),flr((y/8)/8)),1)==true) or (fget(mget(flr((x+15)/8),flr(y/8)),1)==true) then return true end
 if t==0 and (fget(mget(flr(x/8),flr(y/8)),1)==true) and (fget(mget(flr(x/8),flr((y+15)/8)),1)==true) then pl.x+=2 end
 if t==0 and (fget(mget(flr((x+15)/8),flr(y/8)),1)==true) and (fget(mget(flr((x+15)/8),flr((y+15)/8)),1)==true) then pl.x-=2 end
 
 if t==1 and (fget(mget(flr(x/8),flr((y+pl.dy+15)/8)),1)==true) or (fget(mget(flr((x+8)/8),flr((y+pl.dy+15)/8)),1)==true) then return true end
 return false
end

function _draw()
 ss_menu()
 cls()
 map()
 if lives == 3 then print("♥ ♥ ♥",55,38,8) end
 if lives == 2 then print(" ♥ ♥",58,38,8) print("♥",51,38,0) end
 if lives == 1 then print(" ♥",70,38,8) print("♥ ♥",50,38,0) end
 print("escape the teacher! ➡️⬅️⬆️ ",20,140,12)
 print("you lose!",52,319,8)
 if lives>0 then print("retry? ❎",52,369,5) end
 print("you win!",55,189,10)
 print("escape the teacher! ➡️⬅️⬆️ ",20,270,12)
 if not win then
  rectfill(16,150,ts_r/2,154,5)
  spr(flr(sp),ts_r/2-4,149)
 end
 if r>=50 then print("you'll never escape him",217,42,8) end
 //pset(110,8,11)
 print(flr(ts_r/30),71,8,8)
 spr(frames[flr(pl.iw)],pl.x,pl.y,2,2,pl.f)
 spr(e.sp,e.x,e.y-16,2,4,tf)
 spr(frames[flr(running)],255-r,104,2,2,true)
 spr(26,300-r*1.5,96,2,4,true)
 --pset(flr(pl.x),flr(pl.y),11)
 --pset(flr(pl.x),flr(pl.y+15),11)
 --pset(flr(pl.x+15),flr(pl.y),11)
 --pset(flr(pl.x+15),flr(pl.y+15),11)
end
-->8
-- multi-cart helper
function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  load("surviving_sandwehen.p8")
 end
end

