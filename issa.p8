pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
p1 = 0
d = 30
xoff = 60
yoff = 48
s = 0.01 --- speed

x1 = 0
y1 = 0
x2 = 0
y2 = 0
x3 = 0
y3 = 0
x4 = 0
y4 = 0

offset = 0.66
offset2 = 1.33
offset3 = 4.5

-- ball
bx = 64
by = 64
bvx = 1
bvy = 0
br = 3

gmo = 0
win = 0

function _init()
 zeit:init()
end

function _update()

 -- stop wenn game over oder win
 if gmo == 1 or win == 1 then
  return
 end

 zeit:upd()

 if btn(0) then
  p1 += s
 end
 if btn(1) then
  p1 -= s
 end

 upd_ball()

 -- game over
 if bx > 90 or by > 90 then
  gmo = 1
 end

 -- win (explosion = rausgeflogen)
 if bx < 0 or bx > 128 or by < 0 or by > 128 then
  win = 1
 end

 x1 = cos(p1)*d + xoff
 y1 = sin(p1)*d + yoff

 x2 = cos(p1+offset)*d + xoff
 y2 = sin(p1+offset)*d + yoff

 x3 = cos(p1+offset2)*d + xoff
 y3 = sin(p1+offset2)*d + yoff

 x4 = cos(p1+offset3)*d + xoff
 y4 = sin(p1+offset3)*d + yoff

end

function _draw()
 ss_menu()
 cls()
 map(0,0,0,0,1000,15000)

 spr(3,x1,y1,2,2)
 spr(98,x2,y2,2,2)
 spr(214,x3,y3,2,2)
 spr(211,x4,y4,2,2)

 circfill(bx,by,br,9)

 print("ballx:"..bx,10,10,7)
 print("gmo: "..gmo,10,20,8)

 zeit:drw()

 -- game over
 if gmo == 1 then
  print("game over",40,60,8)
 end

 -- win
 if win == 1 then
  print("you win!",40,60,11)
 end

end--
-->8
--ball
function upd_ball()
-- ball bewegen
 bx += bvx
 by += bvy

 -- ball an bildschirmrand abprallen lassen
 if bx < br or bx > 127-br then
  bvx = -bvx
 end

 if by < br or by > 127-br then
  bvy = -bvy
 end
 
   -- kollision mit figuren
 check_player_collision(x1+8,y1+8)
 check_player_collision(x2+8,y2+8)
 check_player_collision(x3+8,y3+8)
 check_player_collision(x4+8,y4+8)
end

function check_player_collision(px,py)
 -- abstand ball -> spielfigur
 local dx = bx - px
 local dy = by - py
 local dist = sqrt(dx*dx + dy*dy)

 -- kollisionsradius:
 -- figur ist 16x16, deshalb etwa 10 pixel
 local hitdist = br + 8

 if dist < hitdist then
  -- normalisieren
  local nx = dx / dist
  local ny = dy / dist
		sfx(0)
  -- ball aus der figur heraussetzen,
  -- damit er nicht kleben bleibt
  bx = px + nx * hitdist
  by = py + ny * hitdist

  -- abprall-formel
  local dot = bvx*nx + bvy*ny
  bvx = bvx - 2 * dot * nx
  bvy = bvy - 2 * dot * ny
 end
end
-->8
--zeit
zeit = {
	farbe1 = 5,
	farbe2 = 8,
	ztst = 	2
	, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {124,125,126,127}, --sprites
	x = 12,
	y = 100,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("surviving_sandwehen.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("surviving_sandwehen.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or won==true or win==1 or win==true then ss_finish(1) end
 if books~=nil and maxbooks~=nil and books>=maxbooks then ss_finish(1) end
 if gmo==2 then ss_finish(1) end
 if gmo==1 then ss_finish(2) end
 if t~=nil and t<0 then ss_finish(2) end
 if px~=nil and px2~=nil and px>122 then ss_finish(1) end
 if px~=nil and px2~=nil and px2>px then ss_finish(2) end
 if pdl1y~=nil and pdl2y~=nil and time()>10 then ss_finish(1) end
end

