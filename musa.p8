pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--funktionen/functions

function _init()
	zeit:init()
	px = 100
	py = 100
	won = 0
end

function _update()
	zeit:upd()
	if zeit.zta==0 then
		gmo = 1
	end
	
	if btn(0) then
		px = px - 1
	end
	
	if btn(1) then
		px = px + 1
	end
	
	if btn(2) then
		py = py - 1
	end
	
	if btn(3) then
		py = py + 1
	end
	
end

function _draw()
	cls()
	map()
	spr(5,px,py)
	spr(6,60,60)
	if px < 10 and py < 30 then
		won = 1
		print("gewonnen! ",50,10,11)
	end
	
	
	print("mach das",10,90,11)
	zeit:drw()
end
-->8
--zeit/timer
zeit = {
	farbe1 = 5,
	farbe2 = 8,
	ztst = 10, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {12,13,14,15}, --sprites
	x = 12,
	y = 100,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

