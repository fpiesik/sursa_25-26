pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	zeit:init()
	tuer = {192,64,68,72,76}
	tuerx= 87
	tuery = 32
end

function _update()
	zeit:upd()
end

function _draw()
 ss_menu()
	cls(12)
	map()
	zeit:drw()
	local frm=flr(zeit.zta*#tuer)+1
	spr(tuer[frm],tuerx,tuery,3,3)
	print(frm)
end


-->8
--zeit
zeit = {
	farbe1 = 11,
	farbe2 = 8,
	ztst = 8, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {12,13,14,15}, --sprites
	x = 12,
	y = 100,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	
	end
}

-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("surviving_sandwehen.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("surviving_sandwehen.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or win==1 or win==true then ss_finish(1) end
 if gameover==true then
  if time_left~=nil and time_left<=0 then ss_finish(1)
  else ss_finish(2) end
 end
 if coll~=nil and coll>0 then ss_finish(2) end
 if hit~=nil and hit==1 then ss_finish(2) end
 if failure==true then ss_finish(2) end
 if verloren==true then ss_finish(2) end
 if gamestate~=nil and gamestate==1 then
  if score~=nil and score>=10 then ss_finish(1)
  else ss_finish(2) end
 end
 if tuer~=nil and zeit~=nil and zeit.zt<=0 then ss_finish(1) end
 if punkte~=nil and punkte>=5 then ss_finish(1) end
 if justgo~=nil and t~=nil and t==0 then ss_finish(2) end
 if t~=nil and won~=nil and t==0 and won==0 then ss_finish(2) end
end

