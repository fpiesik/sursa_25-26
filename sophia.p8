pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--hauptkode
function _init()
zeit:init()
s = 1 --sprite
l = 11 --lehrerin
px = 40 --player position
px2 = 0 --position lehrer
mx = 0 --map x position
btggl = 0 --button toggle 
mapr = 0 --map
end

function _draw()


cls()
map(0,mapr)

 if px2 > px then 
 	mapr = 16
 else
		
		camera(px-50,0)
		zeit.x= px-50
		spr(s,px,94,1,1)
		spr(l,px2,70,4,4)
		print(px,px,0)
		print("run!",55,20,7)
 
	end
	
zeit:upd()
zeit:drw()

 px2 = px2 + 2/3
 

 if btnp(1) and btggl == 0 then 
 	s = s + 1
 	if s>10 then s = 3 end
 	px = px + 4
 	btggl = 1
 end
 
 if btnp(0) and btggl == 1 then 
 	s = s + 1/5
 	if s>10 then s = 3 end
 	px = px + 1
 	btggl = 0
 end
 
 if px > 122 then
  mx = mx + 1
 end


 


end

-->8
--zeit
zeit = {
	farbe1 = 11,
	farbe2 = 10,
	farbe3 = 9,
	farbe4 = 8,
	ztst = 10, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {17,18,19,20}, --sprites
	x = 12,
	y = 110,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

-->8
--desiner: sophia & delal
--idee by: sophia
--teacher design by: delal
--player design by: pico-8
--dekoration by: sophia & delal
--kode by: sophia
