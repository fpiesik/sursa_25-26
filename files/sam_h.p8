pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

-- mensa escape hardcore

player={
 x=64,
 y=110,
 w=8,
 h=8,
 speed=2
}

ingo={
 x=64,
 y=20,
 speed=0.5
}

foods={}
score=0
gameover=false
time_left=30*10 -- 30 sekunden (30 fps)

function _init()
 for i=1,6 do
  spawn_food()
 end
end

function spawn_food()
 add(foods,{
  x=rnd(120),
  y=ingo.y,
  spd=1+rnd(2)
 })
end

function _update()

 if gameover then
  if btnp(4) then
   score=0
   foods={}
   gameover=false
   time_left=30*16
   ingo.speed=0.5
   for i=1,6 do
    spawn_food()
   end
  end
  return
 end

 -- timer runterzれさhlen
 time_left-=1
 if time_left<=0 then
  gameover=true
 end

 -- schwierigkeit erhれへhen
 if time_left%150==0 then
  ingo.speed+=0.1
  spawn_food()
 end

 -- spieler bewegung
 if btn(0) then
  player.x-=player.speed
 end

 if btn(1) then
  player.x+=player.speed
 end

 player.x=mid(0,player.x,120)

 -- ingo folgt schneller
 if player.x>ingo.x then
  ingo.x+=ingo.speed
 elseif player.x<ingo.x then
  ingo.x-=ingo.speed
 end

 -- essen bewegen
 for f in all(foods) do
  f.y+=f.spd

  if f.y>128 then
   del(foods,f)
   spawn_food()
   score+=1
  end

  -- collision
  if abs(player.x-f.x)<2
  and abs(player.y-f.y)<2 then
   gameover=true
  end
 end
end

function _draw()
 ss_menu()

 cls(3)

 -- boden
 rectfill(0,100,128,128,4)

 -- tische
 spr(65,10,90,40,100,6)
 spr(85,80,90,110,100,6)
 spr(90,80,90,40,100,6)
 -- ingo
 spr(17,ingo.x,ingo.y)
 print("ingo",ingo.x-4,ingo.y-6,7)

 -- spieler
-- spr(1,player.x,player.y,player.x+8,player.y+8,11)
 spr(1,player.x,player.y)
 -- essen
 for f in all(foods) do
  circfill(f.x,f.y,3,9)
 end

 -- scoreq
 print("score:"..score,2,2,7)

 -- timer anzeigen
 print("time:"..flr(time_left/30),90,2,7)

 if gameover then
  if time_left<=0 then
   print("du hast uberlebt!",28,60,11)
  else
   print("ingo hat dich!",30,60,8)
  end
  print("press y",48,70,7)
 end
end
-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("sursa.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("sursa.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or win==1 or win==true then ss_finish(1) end
 if gameover==true then
  if time_left~=nil and time_left<=0 then ss_finish(1)
  else ss_finish(2) end
 end
 if coll~=nil and coll>0 then ss_finish(2) end
 if hit~=nil and hit==1 then ss_finish(2) end
 if failure==true then ss_finish(2) end
 if verloren==true then ss_finish(2) end
 if gamestate~=nil and gamestate==1 then
  if score~=nil and score>=10 then ss_finish(1)
  else ss_finish(2) end
 end
 if tuer~=nil and zeit~=nil and zeit.zt<=0 then ss_finish(1) end
 if punkte~=nil and punkte>=5 then ss_finish(1) end
 if justgo~=nil and t~=nil and t==0 then ss_finish(2) end
 if t~=nil and won~=nil and t==0 and won==0 then ss_finish(2) end
end

