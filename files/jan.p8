pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
y = 13

x = 8

won = 0
gmo = 0 
coll = 0
function _init()
	zeit:init()
end

function _update()
	zeit:upd()
end

function _draw()
 ss_menu()
	cls(1)
	map()
	spr(134,y,x,2,2)
	zeit:drw()
	if coll >= 4 then
		 won = 1
	end
	if zeit.zta <= 0 then
		if coll < 4 then
			gmo = 1
		end
	end
	--print(mget(mx,my))
 
 local mx = y/8+1
 local my = (x-4)/8+1
 if (mget(mx,my)==10) then
		mset(mx,my,11)
		sfx(0)
		coll = coll + 1
	end
--pr(1,x,y,2,2) 
 if btn(0) then 

 x = x - 1

 end

 if btn(1) then

 x = x + 1

 end

 if btn(2) then 

 y = y - 1

 end

 if btn(3) then
 y = y + 1

 end

 if won == 1 then
 	print("gewonnen", 50,60,8)
 end
 
 if gmo == 1 then
 	print("lose", 50,60,8)
 end
end


-->8
--zeit
zeit = {
	farbe1 = 9,
	farbe2 = 8,
	ztst = 12, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {76,77,78,79}, --sprites
	x = 12,
	y = 120,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}
-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("sursa.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("sursa.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or won==true or win==1 or win==true then ss_finish(1) end
 if books~=nil and maxbooks~=nil and books>=maxbooks then ss_finish(1) end
 if gmo==2 then ss_finish(1) end
 if gmo==1 then ss_finish(2) end
 if t==0 and t<0 then ss_finish(2) end
 if px~=nil and px2~=nil and px>122 then ss_finish(1) end
 if px~=nil and px2~=nil and px2>px then ss_finish(2) end
 if pdl1y~=nil and pdl2y~=nil and time()>10 then ss_finish(1) end
end

