pico-8 cartridge // http://www.pico-8.com
version 43
__lua__

b1_x=50
b1_y=50

b2_x=70
b2_y=50

b3_x=30
b3_y=50

b4_x=20
b4_y=60

b5_x=30
b5_y=70

b6_x=50
b6_y=60

b7_x=40
b7_y=50

b_spr={1,2,3,4,33,34,35}

function _init()
 music()
end

function _update()
	upd_balloons()
 if btnp(4) or btnp(5) then
  load("../sursa.p8")
 end
end

function _draw()
 cls()
 map()
 drw_balloons()
 
 x=5 -- x-position
 y=1 -- y-position
 cl=7 -- textfarbe
 za=8 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 --rectfill(x,y,x+100,y+50,6)
 ?"abschluss!",45,y,cl
 ?"deine arbeit hat sich gelohnt",x,y+za,cl
 --?"herr wegner dir deinen",x,y+za*2,cl
 --?"abschluss, stolz und",x,y+za*3,cl
 --?"zufrieden mit deinem weg",x,y+za*4,cl
	--?"druecke c oder 🅾️",x,y+za*5,cl
end
-->8
function upd_balloons()
	b1_x=b1_x-0.2
 b1_y=b1_y-0.3
 
 b2_x=b2_x-0.15
 b2_y=b2_y-0.3
 
 b3_x=b3_x+1
 b3_y=b3_y-0.2
 
 b4_x=b4_x+0.2
 b4_y=b4_y-0.5
 
 b5_x=b5_x+0.15
 b5_y=b5_y-0.35
 
 b6_x=b6_x+1
 b6_y=b6_y-0.1
 
 b7_x=b7_x+0.5
 b7_y=b7_y-0.2
 
end

function drw_balloons()
	 spr(b_spr[1],b1_x,b1_y,1,2)
	 spr(b_spr[2],b2_x,b2_y,1,2)
	 spr(b_spr[3],b3_x,b3_y,1,2)
	 spr(b_spr[4],b4_x,b4_y,1,2)
	 spr(b_spr[5],b5_x,b5_y,1,2)
	 spr(b_spr[6],b6_x,b6_y,1,2)
	 spr(b_spr[7],b7_x,b7_y,1,2)
end	
__gfx__
