pico-8 cartridge // http://www.pico-8.com
version 42
__lua__


function _draw()
 cls()
 map()
 x=5
 y=96
 cl=7
-- za=1
 drw_lehrer()
 drw_uhr(110,13,5)
 print("du hast leider zu oft verloren",x,y,cl)
 --print("du hast leider zu oft verloren",x,y+za,cl)
 --print("du hast leider zu oft verloren",x,y+za*2,cl)
 --print("du hast leider zu oft verloren",x,y+za*3,cl)
	--print("du hast leider zu oft verloren",x,y+za*4,cl)
 --print("du hast leider zu oft verloren",x,y+za*5,cl)
 --print("du hast leider zu oft verloren",x,y+za*6,cl)
end
-->8
function drw_lehrer()
	rf={0,4,3,2,5,7,4,1} --reihenfolge
	t = time()
	for i=0,7 do
	 local a = rf[i+1]
 	if (a<4 and t>=i) spr(16+a,30+a*10,45)
 	if (a>=4 and t>=i) spr(16+a,30+(a-4)*10,19,1,1,1,0)
 end
end

function drw_uhr(x,y,r)
	circfill(x,y,r,6)	
	for i=0, 7 do
		pset(x+sin(i/8)*(r-2),y+cos(i/8)*(r-2),0)
	end
	t = time()/60+0.2
	local cx = sin(t)*r
	local cy = cos(t)*r	
	line(x,y,x+cx,y+cy,2)
	
	--circfill(x+cx,y+cy,1,2)
	? x
end
