pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
--😐▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒😐
--▒------------------------------▒
--▒----basketball von toprak ----▒
--▒------------------------------▒
--😐▒▒▒▒▒▒▒▒▒▒▒▒▒▒▒😐
gamestate = 0
score = 0
b = 0
bx = 90
by = 40
xbb=0
ybb=0
timer = 20
timespeed = 0.02
function _draw()
 ss_menu()
	cls()
	map()
 print(score,5,10,0)
 print("timer: " .. flr(timer), 5, 20)
 if gamestate == 0 then 
		print("❎ = shoot", 40, 5, 0)
	end
	if gamestate == 1 then
	camera(500,0)
	end
	if gamestate == 1 then
	print("your score is " .. score, 530,60,7)
	end
	if gamestate == 1 then
	print("press ❎ to try again!",520,100,12)
	end
	if gamestate == 1 and score == 0
	then spr(133,555,70) print("try again",540,30,8)
	elseif gamestate == 1 and score <= 9
	then spr(134,555,70) print("good try but try again",515,30,9)
	elseif gamestate == 1 and score >= 10
	then spr(135,555,70) print("you win!",545,30,12)
	end
	if gamestate == 1 and btnp(❎)
	then gamestate = 0 score = 0 timer = 60 camera(0)
	end
	timerr()
	angle1()
	fire_shot1()
 upd_shot()
	drw_shot()
end

function timerr()
 if timer ~= 0 then
timer -= timespeed
end
 if timer <= 0 then
gamestate = 1
end
end

function fire_shot1()
	if btnp(4) then 
		fire_shot()
	end
end

function angle1()
	if not btnp(❎)then 
		angle += 0.02
	else 
		fire_shot()
		angle = angle
		sfx(1)
	end
end
function _update60()
 if (mget(flr(xbb)/8,flr(ybb)/8)==21)
  then xbb=0 score +=1 sfx(2) end
   if (mget(flr(xbb)/8,flr(ybb)/8)==22)
  then xbb=0 score +=1 sfx(2) end
   if (mget(flr(xbb)/8,flr(ybb)/8)==37)
  then xbb=0 score+=1 sfx(2) end
   if (mget(flr(xbb)/8,flr(ybb)/8)==38)
  then xbb=0 score+=1 sfx(2) end 
end

-->8
angle = 0.9
power = 1
cannon_x = 40
cannon_y = 70
gravity = 0.3
shots = {}
x = cannon_x
y = cannon_y
function fire_shot()
 local muzzle_len = 10
 local muzzle_x = cannon_x + cos(angle) * muzzle_len
 local muzzle_y = cannon_y - sin(angle) * muzzle_len
 local speed = power * 5

 add(shots, {
  x = muzzle_x,
  y = muzzle_y,
  vx = cos(angle) * speed,
  vy = -sin(angle) * speed
 })
end

function upd_shot()
-- alle projektile bewegen
 for i=#shots,1,-1 do
  local s = shots[i]
  s.x += s.vx
  s.y += s.vy
  s.vy += gravity
  -- loeschen, wenn ausserhalb des screens
  if s.x < 0 or s.x > 127 or s.y > 127 then
   deli(shots, i)
  end
    xbb=s.x
  ybb=s.y
 end
end

function drw_shot()
	local barrel_len = 12
 local bx = cannon_x + cos(angle) * barrel_len
 local by = cannon_y - sin(angle) * barrel_len
 line(cannon_x, cannon_y, bx, by, 12)
 -- alle projektile zeichnen
 for s in all(shots) do
  spr(b,s.x-8,s.y,2,2)
 end
 
end
-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("sursa.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("sursa.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or win==1 or win==true then ss_finish(1) end
 if gameover==true then
  if time_left~=nil and time_left<=0 then ss_finish(1)
  else ss_finish(2) end
 end
 if coll~=nil and coll>0 then ss_finish(2) end
 if hit~=nil and hit==1 then ss_finish(2) end
 if failure==true then ss_finish(2) end
 if verloren==true then ss_finish(2) end
 if gamestate~=nil and gamestate==1 then
  if score~=nil and score>=10 then ss_finish(1)
  else ss_finish(2) end
 end
 if tuer~=nil and zeit~=nil and zeit.zt<=0 then ss_finish(1) end
 if punkte~=nil and punkte>=5 then ss_finish(1) end
 if justgo~=nil and t~=nil and t==0 then ss_finish(2) end
 if t~=nil and won~=nil and t==0 and won==0 then ss_finish(2) end
end

