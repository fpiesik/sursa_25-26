pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()

		zeit:init()

  v = 0
 b = 10

	x = 60
	y = 112
	
	ywin = 8 --y collision window
	xwin = 16 --x collision window
	collx = 0 --collx
	colly = 0 --colly
	
	s = 2
	
	snowb = {
		x = -20,
		y = rnd(1)+100
	}
	
	gmo = 0 --game over
	
	pll = {3,45}
	plr = {1,3}
	pls = 13
	frm = 1
	
	plyohit = 1 -- play hit sound 2
	ply_hit = 0 -- play hit sound
	music(0)
end


function _draw()
 ss_menu()
zeit:upd()
		--frame count
	frm = frm + 0.1
	if frm >= (#pll + 1) then
		frm = 1
	end
	local rfr = flr(frm) -- round frame
	---------------
	
	cls(6)
	if gmo == 0 then
	
		spr(11, 80, -20, 2, 2)
		map(10,10)
		
		spr(35,snowb.x,snowb.y,2,2)
		snowb.y = snowb.y+8
		
		if snowb.y > 120 then
			snowb.y = -20
			snowb.x = rnd(100)+10
		end
	       --bewegung	
	 if btn(0) then      
	 	spr(pll[rfr],x,y,2,2)
	 end 
	 if btn(1) then      
	 	spr(plr[rfr],x,y,2,2)
	 end 
	 if not btn(0) and not btn(1) then
	 	spr(pls,x,y,2,2)
	 end
	 
	 if btn(0) then 
	 	x = x - s
	 if x<0then
	 x=0
	 end
	end
	 if btn(1) then
	 	x = x + s
	if x>120 then
	x=120
	end
	end
	
	  --kolison
	 colly = 0
	 collx = 0
		if snowb.y > y - ywin and snowb.y < y + ywin then --y
			colly = 1
		end
		
	 if snowb.x + 8 >= x and snowb.x + 8 < x + xwin then --x
			collx = 1
		end
		
		if collx == 1 and colly == 1 then
		 gmo = 1
		 ply_hit = 1
		end
		 
	print("press <- -> to walk ",20,100,14)
	--timer
	
	 b = zeit.zt
	 
	 
	 if b <= v then 
	 b = 0

	 gmo=2
	 end

		
		end
		
		if plyohit == 1 and gmo == 2 then
	 music(-1)
	 sfx(2)
	 plyohit = 0
	 end
	 
		if ply_hit == 1 then
	 		music(-1)
	 		sfx(1)
	 		ply_hit = 0
	 end
	 	
		if gmo==1 then
	 	--map(10,10)
	 	spr(135,30,30,8,8)
	 end
	 if gmo==2 then
	 	spr(5 ,40,40,4,4)    
  	spr(9,70,40,4,4)
  end
  
  zeit:drw()
 end
 
-->8

     --bewegung vom spieler

spr(1,x,y,2,2) 
 if btn(0) then 

 x = x - s

 end

 if btn(1) then

 x = x + s

 end

 if btn(2) then 

 y = y - s

 end

 if btn(3) then
 y = y + s

 end

-->8
--zeit
zeit = {
	farbe1 = 15,
	farbe2 = 8,
	ztst = 10, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {144,145,146,147}, --sprites
	x = 12,
	y = 105,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("surviving_sandwehen.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("surviving_sandwehen.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or won==true or win==1 or win==true then ss_finish(1) end
 if books~=nil and maxbooks~=nil and books>=maxbooks then ss_finish(1) end
 if gmo==2 then ss_finish(1) end
 if gmo==1 then ss_finish(2) end
 if t~=nil and t<0 then ss_finish(2) end
 if px~=nil and px2~=nil and px>122 then ss_finish(1) end
 if px~=nil and px2~=nil and px2>px then ss_finish(2) end
 if pdl1y~=nil and pdl2y~=nil and time()>10 then ss_finish(1) end
end

