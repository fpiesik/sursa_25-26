pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function _update()
 if btnp(4) then
 	load("kl-5-game.p8")
 end
end

function _draw()
	t = time()
 cls()
 map()
 x=10 -- x-position
 y=70 -- y-position
 cl=3 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"klasse 5",50,y,cl
 ?"du hattest einen tollen tag",x,y+za,cl
 ?"bis auf die erste stunde.",x,y+za*2,cl
 ?"mathe",x,y+za*3,cl
	?"druecke c oder 🅾️",x,y+za*4,cl
	--?flr(t%2)
	
	if flr(t%2) == 0 then
		spr(96,72,48,2,2)
	else
		spr(98,72,48,2,2)	
	end
	 
	if flr(t%2) == 0 then
	 spr(32,40,48,1,2)
	else
	 spr(33,40,48,1,2)
	end
	
	if flr(t%2) == 0 then
	 spr(36,48,48,2,1)
	else
	 spr(52,48,48,2,1)
	end
	
	if flr(t%2) == 0 then
	 spr(64,32,8,2,2)
	else
	 spr(66,32,8,2,2)
	end
	
	if flr(t%2) == 0 then
	 spr(38,72,0,1,2)
	else
	 spr(39,72,0,1,2)
	end
	
	if flr(t%2) == 0 then
	 spr(34,88,40,1,1)
	else
	 spr(35,88,40,1,1)
	end 
	
	if flr(t%2) == 0 then
	 spr(34,64,16,1,1)
	else
	 spr(35,64,16,1,1)
	end
	
	if flr(t%2) == 0 then
	 spr(35,64,40,1,1)
	else
	 spr(34,64,40,1,1)
	end 
	
	if flr(t%2) == 0 then
	 spr(35,64,0,1,1)
	else
	 spr(34,64,0,1,1)
	end
	
	if flr(t%2) == 0 then
	 spr(50,48,8,1,1)
	else
	 spr(51,48,8,1,1)
	end     
	
	if flr(t%2) == 0 then
	 spr(50,32,40,1,1)
	else
	 spr(51,32,40,1,1)
	end  
	
	if flr(t%2) == 0 then
	 spr(51,88,16,1,1)
	else
	 spr(50,88,16,1,1)
	end  
	
	if flr(t%2) == 0 then
	 spr(51,64,56,1,1)
	else
	 spr(50,64,56,1,1)
	end 
	
end
