pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function _update()
 if btnp(4) then
 	load("kl-9-game.p8")
 end
end

function _draw()
 cls()
 map()
 x=10 -- x-position
 y=70 -- y-position
 cl=11 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"klasse 9",50,y,cl
 ?"jetzt im 9. jahrgang",x,y+za,cl
 ?"wird es ernst, die",x,y+za*2,cl
 ?"vorbereitung auf die",x,y+za*3,cl
 ?"10. klasse.du beginnst im",x,y+za*4,cl
	?"lesegarten zu lernen.",x,y+za*5,cl
 ?"druecke c oder 🅾️",x,y+za*6,cl
end
