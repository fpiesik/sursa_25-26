pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
m1x=30 --x-position mensch-1
m1y=40

m2x=36
m2y=40

m3x=42
m3y=40

m4x=48
m4y=40

m5x=54
m5y=40

w1x=85 --x-position wolke1
w2x=65 --x-position wolke1
w3x=49 --x-position wolke1
w4x=30 --x-position wolke1
w5x=10 --x-position wolke1
w6x=-7 --x-position wolke1

function _update()
	t=time()
 if btnp(4) then
 	load("kl-5-intro.p8")
 end
end

function _draw()
 --pal(0,12,0)
 cls(7)
 map()
 --maedchen_x=maedchen_x+0.1
 spr(35,m1x,m1y)
 spr(36,m2x,m2y)
 spr(37,m3x,m3y)
 spr(38,m4x,m4y)
 spr(39,m5x,m5y)
 wolken()
 spr(82,90,35,4,2)
-- print(t)
 if t>2 and t < 2.1 then
 	spr(71,92,35,2,2)
 end
 --text
 x=10 -- x-position
 y=70 -- y-position
 cl=2 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"du kommst frisch aus der",x,y,cl
 ?"grundschule und wurdest",x,y+za,cl
 ?"an der sandwehen schule",x,y+za*2,cl
 ?"aufgenommen",x,y+za*3,cl
	?"deine reise",x,y+za*4,cl
 ?"durch die jahre beginnt:",x,y+za*5,cl
 ?"druecke c oder 🅾️",x,y+za*6,cl
end

function wolken()
 w1x=w1x+0.50
 w2x=w2x+0.25
 w3x=w3x+0.19
 w4x=w4x+0.15
 w5x=w5x+0.15
 w6x=w6x+0.14
 
	spr(14,w1x,0,2,2)
	spr(14,w2x,0,2,2)
	spr(14,w3x,0,2,2)
	spr(14,w4x,0,2,2)
	spr(14,w5x,0,2,2)
	spr(14,w6x,0,2,2)


end
__gfx__
