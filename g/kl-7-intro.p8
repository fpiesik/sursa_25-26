pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
x_guy=20

function _update()
 if btnp(4) then
 	load("kl-7-game.p8")
 end
end

function _draw()
 cls()
 map()
 spr(2,x_guy,15,2,2)
 x_guy=x_guy+1
 x=10 -- x-position
 y=70 -- y-position
 cl=3 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"klasse 7",50,y,cl
 ?"dein verhalten war nicht",x,y+za,cl
 ?"immer vorbildlich, und als",x,y+za*2,cl
 ?"strafe musstest du im",x,y+za*3,cl
 ?"7. jahrgang muell sammeln.",x,y+za*4,cl
	?"druecke c oder 🅾️",x,y+za*5,cl
end
__gfx__
