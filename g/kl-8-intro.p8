pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
m1x=45
m1y=55


function _update()
	upd_mensch()
 if btnp(4) then
 	load("kl-8-game.p8")
 end
end

function _draw()
 cls()
 map()
 drw_mensch()
 map(16)
 x=10 -- x-position
 y=70 -- y-position
 cl=9 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"klasse 8",50,y,cl
 ?"im 8. jahrgang stand das",x,y+za,cl
 ?"sportfest an, und du gabst",x,y+za*2,cl
 ?"beim rennen alles",x,y+za*3,cl
 ?"druecke c oder 🅾️",x,y+za*4,cl
end
-->8
function upd_mensch()
 m1x=m1x+0.2
 m1y=m1y-0.5
end

function drw_mensch()
	t=time()
	t=flr(t*4%2)

	if t==0 then 
		spr(1,m1x,m1y,2,2)
	else
		spr(3,m1x,m1y,2,2)
	end
	
end
