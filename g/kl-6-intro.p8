pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
m1x=40
m1y=30

function _update()
 if btnp(4) then
 	load("kl-6-game.p8")
 end
end

function _draw()
 cls()
 map()
 m1x=m1x+0.1
 spr(34,m1x+10,m1y-10,2,2)
 spr(34,m1x+8,m1y-25,2,2)
 spr(34,m1x-10,m1y-19,2,2)
 spr(34,m1x+10,m1y-18,2,2)
 spr(34,m1x+18,m1y-30,2,2)
 x=10 -- x-position
 y=70 -- y-position
 cl=4 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"klasse 6",50,y,cl
 ?"im 6. jahrgang stand das",x,y+za,cl
 ?"fussballturnier an.",x,y+za*2,cl
 ?"durch hartes training",x,y+za*3,cl
 ?"hast du fuer dich und",x,y+za*4,cl
	?"dein team entscheidende",x,y+za*5,cl
 ?"chancen geholt.",x,y+za*6,cl
 ?"druecke c oder 🅾️",x,y+za*7,cl
end
