pico-8 cartridge // http://www.pico-8.com
version 42
__lua__
function _update()
 if btnp(4) then
 	load("kl-10-game.p8")
 end
end

function _draw()
 cls()
 map()
 x=10 -- x-position
 y=70 -- y-position
 cl=12 -- textfarbe
 za=7 -- zeilenabstad
 --drw_lehrer()
 --drw_uhr(20,20,5)
 ?"klasse 10",50,y,cl
 ?"im 10. jahrgang steht die",x,y+za,cl
 ?"grosse pruefung an.",x,y+za*2,cl
 ?"du darfst",x,y+za*3,cl
 ?"nicht reden und schreibst",x,y+za*4,cl
	?"deine arbeiten",x,y+za*5,cl
 ?"druecke c oder 🅾️",x,y+za*6,cl
end
