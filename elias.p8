pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
x=100
y=10
gmo = 0 --gameover?

lx =77
ly =77

win = 0

function _init()
	zeit:init()
	music()
end

function _update()
	zeit:upd()
 if btn(0) then x-=1 end 
 if btn(1) then x+=1 end 
 if btn(2) then y-=1 end 
 if btn(3) then y+=1 end 
end

function _draw()
 ss_menu()
 cls()
 
 if gmo == 0 and win ==0 then
	 map()
	 spr(2,x,y,4,4)
	 spr(77,75,80,3,4)
	 line(lx,0,lx,ly,3)
	 print("komm ins klassenzimmer aber lass",12)
	 print("dich nicht erwischen")
		zeit:drw()
	end
	
	if gmo == 1 then
		print("game over",50,60,9)
	end
	
	if zeit.zta==0 then
		gmo = 1
	end
	
	if win == 1 then
		print("won!",50,60,9)
	end
	
 if x<10 and y<60 then
	win = 1
 end
	
		if x<lx and x>lx-32 and y < ly then
			gmo = 1
		end
	print(gmo)
	print("x: "..x)
	print("y: "..y)
end

-->8
--zeit
zeit = {
	farbe1 = 11,
	farbe2 = 8,
	ztst = 10, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {26,27,28,29}, --sprites
	x = 12,
	y = 100,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("surviving_sandwehen.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("surviving_sandwehen.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or won==true or win==1 or win==true then ss_finish(1) end
 if books~=nil and maxbooks~=nil and books>=maxbooks then ss_finish(1) end
 if gmo==2 then ss_finish(1) end
 if gmo==1 then ss_finish(2) end
 if t~=nil and t<0 then ss_finish(2) end
 if px~=nil and px2~=nil and px>122 then ss_finish(1) end
 if px~=nil and px2~=nil and px2>px then ss_finish(2) end
 if pdl1y~=nil and pdl2y~=nil and time()>10 then ss_finish(1) end
end

