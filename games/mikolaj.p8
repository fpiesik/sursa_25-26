pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
y1 = 13

x1 = 13

t = 10

mapoff = 0

index = 1
l = {{128,16,25},
				{130,48,25},
		 	{132,80,25},
				{136,112,25},
				{134,16,57},
		 	{138,48,57},
		 	{160,80,57},
				{168,112,57},
				{162,16,89},
				{166,48,89}}
								
function _init()
 index = flr(rnd(#l)) + 1
end

function _draw()
 ss_menu()
 cls(4)
 map(mapoff,0)
 print(t)
 
 if t > 0 then
 t = t - 0.03
 end
 
 if t < 0 then
  print("die zeit ist um du hast vehrloren") end
 
 if t < 0 then 
  mapoff = 17
  sfx(1)   
 end
 if abs(x1-l[index][2])<10 and abs(y1-l[index][3])<10 then
  won=1
  print("gefunden!",46,112,11)
 end
 
 
 
 spr(10,96,97,2,2) --lehrer/in  
 
 spr(4,l[1][2],l[1][3],2,2) --rot
 spr(6,l[2][2],l[2][3],2,2) --kajo
 spr(8,l[3][2],l[3][3],2,2) --gustav
 spr(12,l[4][2],l[4][3],2,2) --dunkelgruen
 spr(2,l[5][2],l[5][3],2,2) --grau
 spr(14,l[6][2],l[6][3],2,2) --heellgruen
 spr(32,l[7][2],l[7][3],2,2) --gelb
 spr(42,l[8][2],l[8][3],2,2) --krawatte
 spr(34,l[9][2],l[9][3],2,2) --orange
 spr(40,l[10][2],l[10][3],2,2) --pink
 spr(16,x1,y1) --curser
 spr(192,0,100,2,2)
 
 print(l[index],0)
 spr(l[index][1],l[index][2]-8,l[index][3],2,2)

 if btn(0) then
  x1 = x1 - 2
 end
 
 if btn(1) then
  x1 = x1 + 2
 end
 
 if btn(3) then
  y1 = y1 + 2
 end
 
 if btn(2) then
  y1 = y1 - 2
 end
end
-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("sursa.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("sursa.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or won==true or win==1 or win==true then ss_finish(1) end
 if books~=nil and maxbooks~=nil and books>=maxbooks then ss_finish(1) end
 if gmo==2 then ss_finish(1) end
 if gmo==1 then ss_finish(2) end
 if t~=nil and t<0 then ss_finish(2) end
 if px~=nil and px2~=nil and px>122 then ss_finish(1) end
 if px~=nil and px2~=nil and px2>px then ss_finish(2) end
 if pdl1y~=nil and pdl2y~=nil and time()>10 then ss_finish(1) end
end

