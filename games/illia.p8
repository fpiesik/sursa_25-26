pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
-- labyrinth buch spiel

x=8
y=16
spd=1
books=0
maxbooks=3
coll = false --collision?
wc = 5 --wall color
gmo = 0 --gameover
time_frames = 30 * 30 

function _init()
	zeit:init()
	music()
end

function _draw()
 ss_menu()
 cls(7)
 map(0,0,0,0,16,16)
 spr(1,x,y)
	if pget(x,y) == wc or pget(x+7,y) == wc or pget(x,y+7) == wc then
		coll = true
	end
 print("books:"..books,1,1,7)
	print("sammle alle bucher,⬇️⬅️⬆️➡️",10,121,7)

 
 if books>=maxbooks then
  print("du hast gewonnen!",25,60,11)
 end
 if gmo == 1 then
  print("du hast verloren!",25,60,8)
	end
	
 zeit:drw()
end


function color_collision(x,y,c)
	return pget(x,y) == c
end

function _update()
	zeit:upd()
 time_frames -= 1

 if time_frames <= 0 then
  gmo = 1
 end

	if coll == false then
	 if btn(0) then x-=spd end
	 if btn(1) then x+=spd end
	 if btn(2) then y-=spd end
	 if btn(3) then y+=spd end
	else 
		gmo = 1
	end
 tx=flr((x+4)/8)
 ty=flr((y+4)/8)

 t=mget(tx,ty)

 -- buch tile = 16
 if t==10 then
 sfx(00)
  books+=1
  mset(tx,ty,0)
 end
 
 if t==11 then
 sfx(00)
  books+=1
  mset(tx,ty,0)
 end
 
 
 if t==26 then
 sfx(00)
  books+=1
  mset(tx,ty,0)
 end
 
end


-->8
--zeit
zeit = {
	farbe1 = 10,
	farbe2 = 8,
	ztst = 30, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {17,18,19,20}, --sprites
	x = 12,
	y = 8,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("sursa.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("sursa.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or won==true or win==1 or win==true then ss_finish(1) end
 if books~=nil and maxbooks~=nil and books>=maxbooks then ss_finish(1) end
 if gmo==2 then ss_finish(1) end
 if gmo==1 then ss_finish(2) end
 if t~=nil and t<0 then ss_finish(2) end
 if px~=nil and px2~=nil and px>122 then ss_finish(1) end
 if px~=nil and px2~=nil and px2>px then ss_finish(2) end
 if pdl1y~=nil and pdl2y~=nil and time()>10 then ss_finish(1) end
end

