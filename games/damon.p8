pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
x = 60
y = 60
s = 1
f = 1
t = 15 	
justgo = 1	
numr = 0 --number right
won = 0
sound_off = 0
function _init()
music(00)
	zeit:init()
 end
function _draw()
 ss_menu()
	if btn(0) then 
  x = x - s 
  f = f + 1
 end
 
 if btn(1) then
  x = x + s
  f = f + 1
 end
 
 if btn(3) then
 	y = y + s
  f = f + 1
 end
 
 if btn(2) then
  y = y - s
 	f = f + 1
 end
 
 if f > 4 then
  f = 1
 end
 
 --t = t - 0.40/15
 t = zeit.zt
 
 if t < 0 then 
  t = 0
 end 
 
 cls(6)
	map()
	print("adjektiv",9,10,5)
	print("nomen",55,10,5)
	print("verben",95,10)
	spr(f,x,y)
	print(flr(t),55,1)
	print("apfel",w1.x,w1.y)
	print("rot",w2.x,w2.y)
	print("fahren",w3.x,w3.y) 
	print("sortiere die woerter",20,35)
	print("ablegem mit ❎",37,83)         
	zeit:upd()
 zeit:drw()
 
	if t == 0 and won == 0 then
		print ("game over",50,70,8)
	if justgo == 1 then
		music(-1)
		sfx(03)
		justgo = 0
	end
	 
	 if won == 1 then
		 music(-2)
		 if sound_off == 0 then 
		 	sfx(04)
		 	sound_off = 1
		 end     
	 end
	 
 end	
 r1.x=x
 r1.y=y
 
 if collision(r1,w1) then
 	w1.x = x
 	w1.y = y
 	if btn(❎) then 
 	w1.y = y-5
 	end
 end
  if collision(r1,w2) then
 	w2.x = x
 	w2.y = y
 	if btn(❎) then 
 	w2.y = y-5
 	end
 end
  
 if collision(r1,w3) then
 	w3.x = x
 	w3.y = y
 	if btn(❎) then 
 	w3.y = y-5
 	end
 end
 
 numr = 0
 
 if collision(w2,t1) then
  numr = numr + 1
 end
 
 if collision(w1,t2) then
  numr = numr + 1
 end
 
 if collision(w3,t3) then
  numr = numr + 1
 end
 
 if numr == 1 then 
 	print("1 von 3",10,0,8)
 end
 
 if numr == 2 then 
 	print("2 von 3",10,0,8)
 end
 
if numr == 3 then 
 	print("you win",50,70,3)
 sfx(04)
 won = 1
 end
 
 numr = 3
end
 
 
-- if collision(w1,t2) then
-- stop print("1 von 3",10,0,8)
 --end
-->8
r1 = { x=10, y=20, w=8, h=8 }
w1 = { x=10, y=100, w=20, h=5 }
w2 = { x=50, y=70, w=20, h=5 }
w3 = { x=90, y=100, w=20, h=5 }

t1 = { x=10, y=10, w=20, h=20 }
t2 = { x=60, y=20, w=20, h=10 }
t3 = { x=100, y=25, w=20, h=10 }
--expanded example
function collision( r1, r2 )
	if  r1.x < r2.x+r2.w
	and r1.x+r1.w > r2.x
	and r1.y < r2.y+r2.h 
	and r1.y+r1.h > r2.y then  
		return true
	else
		return false
	end
end
-->8
--zeit
zeit = {
	farbe1 = 5,
	farbe2 = 8,
	ztst = 12, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {196,197,198,199}, --sprites
	x = 12,
	y = 115,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}

-->8
-- multi-cart helper
ss_done=false
function ss_finish(r)
 if ss_done then return end
 ss_done=true
 cartdata("surviving_sandwehen")
 dset(3,r)
 load("sursa.p8")
end

function ss_menu()
 if (btn(4) and btnp(5))
 or (btn(5) and btnp(4)) then
  cartdata("surviving_sandwehen")
  dset(3,0)
  load("sursa.p8")
 end
 ss_check_finish()
end

function ss_check_finish()
 if won==1 or win==1 or win==true then ss_finish(1) end
 if gameover==true then
  if time_left~=nil and time_left<=0 then ss_finish(1)
  else ss_finish(2) end
 end
 if coll~=nil and coll>0 then ss_finish(2) end
 if hit~=nil and hit==1 then ss_finish(2) end
 if failure==true then ss_finish(2) end
 if verloren==true then ss_finish(2) end
 if gamestate~=nil and gamestate==1 then
  if score~=nil and score>=10 then ss_finish(1)
  else ss_finish(2) end
 end
 if tuer~=nil and zeit~=nil and zeit.zt<=0 then ss_finish(1) end
 if punkte~=nil and punkte>=5 then ss_finish(1) end
 if justgo~=nil and t~=nil and t==0 then ss_finish(2) end
 if t~=nil and won~=nil and t==0 and won==0 then ss_finish(2) end
end

