shoot = {
	angle = 0.9,
	power = 0.7,
	x = 55,
	y = 64,
	gravity = 0.1,
	}
	
function fire_shot()
 local muzzle_len = 0
 local muzzle_x = cannon_x + cos(angle) * muzzle_len
 local muzzle_y = cannon_y - sin(angle) * muzzle_len
 local speed = power * 3

 add(shots, {
  x = muzzle_x,
  y = muzzle_y,
  vx = cos(angle) * speed,
  vy = -sin(angle) * speed
 })
end

function drw_shot()
	local barrel_len = 12
 local bx = cannon_x + cos(angle) * barrel_len
 local by = cannon_y - sin(angle) * barrel_len
 --line(cannon_x, cannon_y, bx, by, 7)
 -- alle projektile zeichnen
	for s in all(shots) do	
	
	rrect( s.x, s.y, 5, 1 )
 end
end
-->8
   --collision
function collision(p,r)
	if  p.x >= r.x
	and p.x <= r.x+r.w
	and p.y >= r.y 
	and p.y <= r.y+r.h then   
		return true
	else
		return false
	end
end

-->8
--zeit
zeit = {
	farbe1 = 5,
	farbe2 = 8,
	ztst = 6, --startzeit
	zt = 0,
	ztstb = 100, --zeit startbreite 
	zta = 0, --zeitanteil
	sprts = {1,2,3,4}, --sprites
	x = 37,
	y = 0,
	br = 100,
	
	frm = 1,
	zta = 1,
	
	init = function(s)
		s.zt = s.ztst
		s.farbe = s.farbe1
	end,
	
	upd = function(s)
		s.zt = s.zt-1/30
		s.frm = 1
		s.br = s.ztstb*s.zta
		s.zta = s.zt/s.ztst
		s.frm = flr(s.zt*5)%(#s.sprts-1)+1
		if s.zta <= 0 then
			s.zta = 0
			s.zt = 0
			s.frm = #s.sprts 
		end 
		if s.zta <= 0.2 then
			s.farbe = s.farbe2
		end 
	end,
	
	drw = function(s)
		rrectfill(s.x,s.y+2,s.br,4,3,s.farbe)
		spr(s.sprts[s.frm],s.x+s.br-4,s.y)
	end
}
