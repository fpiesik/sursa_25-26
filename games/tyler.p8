pico-8 cartridge // http://www.pico-8.com
version 43
__lua__
function _init()
	tme = 1
	sa = 200
	wegner = 49
	laser = 65
	angle = 0.5
	power = 1
	cannon_x = 60
	cannon_y = 66
	shots = {}
	hit = 0
	won = 0 --gewonnen?
-- game over = 139


 player={
     x=1,
     y=59,
     f=33,
     dx=0,
     dy=0,
     max_dx=4,
     max_dy=4,
     acc=0.5,
     boost=4.5,
 }

 gravity=0.4
 friction=0.35
 
 zeit:init()
end

function _update()
  zeit:upd()

	-- winkel aendern
-- if btn(2) then
 -- angle -= 0.005
-- end
 
-- if btn(3) then
--  angle += 0.005
-- end
 
 if player.x > 98 then
 	won = 1
 end
	--schuss
	if tme > 4 then
 	tme = 0
 end
 
 if tme == 0 then
  fire_shot()
 end 
 
 tme = tme + 0.13
 
player.x = mid(0, player.x, 120)
player.y = mid(0, player.y, 120)
 
 
	upd_ply()
	
	-- alle projektile bewegen
 for i=#shots,1,-1 do
  local s = shots[i]
  s.x += s.vx
  s.y += s.vy

		--check ob getroffen
		local bullet = { x=s.x, y=s.y }
		local enemy = { x=player.x, y=player.y, w=8, h=8 }
		if collision( bullet, enemy ) then
			hit=1             
		end
		
  -- loeschen, wenn ausserhalb des screens
  if s.x < 0 or s.x > 127 or s.y > 127 then
   deli(shots, i)
  end
 end
end

function _draw()
 ss_menu()
	cls(12)
	if won == 0 then
	if hit == 0 then
	map()
	drw_ply()
	spr(wegner,72,64)
	spr(laser,65,62)
	print(won,10,20)
	--laser-animation (?)
	if player.f > 40 then
	 player.f = 33
	end
	
	if laser > 76 then
	 laser = 65
	end
	
  --player animation
	if btn(1) then
 	player.f = player.f + 1
  --x = x + s   
 end 

 if btn(0) then
 	player.f = player.f + 1
  --x = x - s
 end
 
 

	--zeichne rrect
 drw_shot()
 
 	zeit:drw()
	
 --zeichne text  
	print("its 8.30",0,o,1) 
	print("go in your class!!!",30,35,1)	
--	print("hit: "..hit,10,40,2)
 end
 if hit == 1 then
 print("game over",45,60,8)
 end
 end
 if won == 1 then
 print("you are in your class",25,60,10)
 end
end
 
 

 

-->8


function upd_ply()
 player.dy+=gravity
 player.dx*=friction

 --controls
 if (btn(0)) then player.dx-=player.acc end -- left
 if (btn(1)) then player.dx+=player.acc end -- right
 if (btnp(4)) then player.dy-=player.boost end -- x

 --limit left/right speed
 player.dx=mid(-player.max_dx,player.dx,player.max_dx)
 --limit fall speed
 if (player.dy>0) then
     player.dy=mid(-player.max_dy,player.dy,player.max_dy)
 end

 --apply dx and dy to player position
 player.x+=player.dx
 player.y+=player.dy

 --simple ground collision
 if (player.y>64) then player.y=64 player.dy=0 end

 --if run off screen warp to other side
-- if (player.x>128) then player.x=-8 end
-- if (player.x<-8) then player.x=128 end
end

function drw_ply()
 spr(player.f,player.x,player.y)

 --ground
-- rectfill(0,118,127,127,13)

 --display info
 --print("dx= "..player.dx)
 --print("dy= "..player.dy)
end
